local FolderName="Chara"
local function LoadKeyframeSequence(fileName)
    local path = FolderName.."/"..fileName
    if not isfile(path) then warn("Arquivo não encontrado:",path) return nil end
    local raw = readfile(path)
    local data = HttpService:JSONDecode(raw)
    local sequence = Instance.new("KeyframeSequence")
    for _, frame in ipairs(data) do
        local keyframe = Instance.new("Keyframe")
        keyframe.Time = frame.Time
        keyframe.Parent = sequence
        for _, poseData in ipairs(frame.Poses) do
            local pose = Instance.new("Pose")
            pose.Name = poseData.Name
            pose.CFrame = CFrame.new(unpack(poseData.CFrame))
            pose.Parent = keyframe
        end
    end
    return sequence
end

