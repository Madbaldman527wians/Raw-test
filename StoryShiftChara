local transitionTimeGlobal = 0.15

local function PlayAnimation(anim,speed,loop)
    if currentAnim==anim then return end
    currentAnim=anim
    getgenv().Animator6D(anim,speed or 1,loop~=false,transitionTimeGlobal)
end

local function GetAnimationLength(anim)
    local length=0
    for _,keyframe in ipairs(anim:GetChildren()) do
        if keyframe:IsA("Keyframe") and keyframe.Time>length then length=keyframe.Time end
    end
    return length
end

-- Atualização de estado humanoid com transição suave
RunService.Heartbeat:Connect(function(dt)
    if comboPlaying then return end

    local state = humanoid:GetState()
    local speed = humanoid.MoveDirection.Magnitude
    local nextAnim = IdleAnim

    if state==Enum.HumanoidStateType.Jumping then
        nextAnim = JumpAnim
    elseif state==Enum.HumanoidStateType.Freefall then
        nextAnim = FallAnim
    else
        if speed < 0.1 then
            nextAnim = IdleAnim
        else
            nextAnim = running and RunAnim or WalkAnim
        end
    end

    if currentAnim ~= nextAnim then
        -- interpolação suave de transição
        if lastAnimData and getgenv().currentAnimator6D then
            for joint, data in pairs(lastAnimData) do
                local motor = FindMotor(joint, getgenv().currentAnimator6D.map, getgenv().currentAnimator6D.lower)
                if motor then
                    motor.C0 = motor.C0:Lerp(data, math.clamp(dt/transitionTimeGlobal, 0, 1))
                end
            end
        end
        PlayAnimation(nextAnim,1,true)
    end

    -- salvar frame atual para próxima transição
    if getgenv().currentAnimator6D and getgenv().currentAnimator6D.seq then
        local frame = getgenv().currentAnimator6D.seq[1].Data
        lastAnimData = {}
        for joint, data in pairs(frame) do
            local motor = FindMotor(joint, getgenv().currentAnimator6D.map, getgenv().currentAnimator6D.lower)
            if motor then
                lastAnimData[joint] = getgenv().currentAnimator6D.savedC0[motor]*data.CFrame
            end
        end
    end
end)

