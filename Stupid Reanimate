

local Plrs = game.Players  
local lp = Plrs.LocalPlayer  
  
local OfcChar = lp.Character  
local OfcH = OfcChar:WaitForChild("Humanoid")  
local Animate = OfcChar:WaitForChild("Animate")  
Animate.Enabled = false  
  
OfcChar.Archivable = true  
local FChar = OfcChar:Clone()  
replicatesignal(OfcH.ServerBreakJoints)  

for _, v in ipairs(OfcChar:GetDescendants()) do  
    if v:IsA("BasePart") then  
        v.Velocity = Vector3.new(0,50,0)  
    end  
end  

FChar.Name = "FChar"  
FChar.Parent = workspace  
lp.Character = FChar  
  
FChar:WaitForChild("Humanoid")  
FChar:WaitForChild("Animate").Enabled = true  
  
workspace.Camera.CameraSubject = FChar.Humanoid  
  
OfcH.Animator:Destroy()  
  
for _, v in ipairs(FChar:GetDescendants()) do  
    if v:IsA("BasePart") or v:IsA("Decal") then  
        v.Transparency = 1  
    end  
end  

-- CORREÇÃO DEFINITIVA: MAPEAR POR ÍNDICE
local AccessoryMap = {}

local realAccessories = {}
local cloneAccessories = {}

for _, v in ipairs(OfcChar:GetChildren()) do
    if v:IsA("Accessory") then
        table.insert(realAccessories, v)
    end
end

for _, v in ipairs(FChar:GetChildren()) do
    if v:IsA("Accessory") then
        table.insert(cloneAccessories, v)
    end
end

for i = 1, math.min(#realAccessories, #cloneAccessories) do
    AccessoryMap[realAccessories[i]] = cloneAccessories[i]
end

local function NoCollision()  
    for _, v in ipairs(OfcChar:GetDescendants()) do   
        if v:IsA("BasePart") then  
            v.CanCollide = false  
            v.Massless = true  
            v.CanQuery = false  
            v.CanTouch = false  
        end  
    end  
end  
  
local RunService = game:GetService("RunService")  
  
local Con2  
local Con   

Con = RunService.PreSimulation:Connect(function()  
  
    NoCollision()  
    OfcChar.Parent = workspace
  
    if not lp.Character or lp.Character ~= FChar then  
        lp.CharacterAdded:Wait()  
  
        if Con then Con:Disconnect() end  
        if Con2 then Con2:Disconnect() end  
  
    end  
  
end)  
  
Con2 = RunService.Heartbeat:Connect(function()  

    lp.SimulationRadius = 999  
    OfcChar.Parent = workspace
  
    -- PARTES
    for _, part in ipairs(OfcChar:GetDescendants()) do  
  
        if part:IsA("BasePart") then  
  
            local clonePart = FChar:FindFirstChild(part.Name, true)  
  
            if clonePart and clonePart:IsA("BasePart") then  
  
                part.CFrame = clonePart.CFrame  
                part.Velocity = Vector3.new(250,250,250)  
                  
            end  
  
        end  
  
    end  

    
    for realAccessory, cloneAccessory in pairs(AccessoryMap) do

        local realHandle = realAccessory:FindFirstChild("Handle")
        local cloneHandle = cloneAccessory:FindFirstChild("Handle")

        if realHandle and cloneHandle then

            realHandle.CFrame = cloneHandle.CFrame
            realHandle.Velocity = Vector3.new(0,50,0)

        end

    end
  
end)

Workspace.FallenPartsDestroyHeight = 0/0
