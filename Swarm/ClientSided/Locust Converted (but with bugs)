	if g then return end
	if i.KeyCode == Enum.KeyCode.E then tg = not tg; eA("sprint", {on = tg})
	elseif i.KeyCode == Enum.KeyCode.Q then eA("attack2")
	elseif i.KeyCode == Enum.KeyCode.R then eA("attack3")
	elseif i.KeyCode == Enum.KeyCode.C then eA("crouch")
	elseif i.KeyCode == Enum.KeyCode.X then eA("sit") end
end)

ws.CurrentCamera.CameraSubject = Hum
