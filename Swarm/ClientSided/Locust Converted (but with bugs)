-- CAPTURA DO ESTADO INICIAL COMPLETO (Para reset perfeito no Unsit/Crouch)
local INITIAL_HIPHEIGHT = Hum.HipHeight
local INITIAL_PART_STATES = {}

-- Desancorar partes, forçar opacidade (Transparência = 0) e registrar estado físico inicial
for _, d in ipairs(C:GetDescendants()) do 
	if d:IsA("BasePart") then 
		d.Anchored = false 
		if d:IsA("MeshPart") then
			d.Transparency = 0
		end
		INITIAL_PART_STATES[d] = {
			CanCollide = d.CanCollide,
			Massless = d.Massless
		}
	end 
end

Hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
Hum:SetStateEnabled(Enum.HumanoidStateType.GettingUp, true)
Hum:SetStateEnabled(Enum.HumanoidStateType.Physics, false)

local DS = C:FindFirstChild("DogServer")
local AF = DS and DS:FindFirstChild("Animations")
local SF = C:FindFirstChild("sounds")
local VF = DS and DS:FindFirstChild("vocals")
local SpF = DS and DS:FindFirstChild("speech")
local ws = workspace
local mR = math.random

local bns = {}
for _, o in ipairs(C:GetDescendants()) do if o:IsA("Bone") then bns[o.Name] = o end end

local abt, aan, aTh = {}, "", {}
local kfEvt = Instance.new("BindableEvent")

local function akt(kf, d, eS)
	d = d > 0 and d or 0.05
	local ti = TweenInfo.new(d, eS or Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
	for _, p in ipairs(kf:GetDescendants()) do
		if p:IsA("Pose") and bns[p.Name] then
			if abt[p.Name] then abt[p.Name]:Cancel() end
			local tw = TS:Create(bns[p.Name], ti, {Transform = p.CFrame})
			abt[p.Name] = tw; tw:Play()
		end
	end
end

local function pke(k)
	kfEvt:Fire(k)
	if k == "step" then
		local f1 = C:FindFirstChild("footsteps") or (SF and SF:FindFirstChild("footsteps"))
		local f2 = C:FindFirstChild("footsteps2") or (SF and SF:FindFirstChild("footsteps2"))
		if f1 and #f1:GetChildren() > 0 then
			local s = f1:GetChildren()[mR(1, #f1:GetChildren())]:Clone()
			s.PlaybackSpeed = Random.new():NextNumber(0.6, 0.7); s.Parent = HRP; s:Play(); DB:AddItem(s, 2)
		end
		if f2 and #f2:GetChildren() > 0 then
			local s = f2:GetChildren()[mR(1, #f2:GetChildren())]:Clone()
			s.PlaybackSpeed = Random.new():NextNumber(0.7, 0.8); s.Parent = HRP; s:Play(); DB:AddItem(s, 2)
		end
	end
end

-- ADAPTAÇÃO NATIVA: IMPLEMENTAÇÃO DO CLASS.SPEED E CLASS.LOOPED SEM USAR MÓDULOS EXTERNOS
local function PT(aN, lp, animSpeed)
	local sq = AF and AF:FindFirstChild(aN)
	if not sq or aan == aN then return end
	
	-- Define a velocidade padrão da animação (Class.Speed) caso não seja informada
	local speed = (animSpeed and animSpeed > 0) and animSpeed or 1
	
	local pA = aan; aan = aN
	for n, t in pairs(aTh) do if n ~= aN then task.cancel(t); aTh[n] = nil end end
	if aTh[aN] then task.cancel(aTh[aN]) end
	
	aTh[aN] = task.spawn(function()
		local kfs = sq:GetKeyframes()
		table.sort(kfs, function(a, b) return a.Time < b.Time end)
		local iF = true
		repeat
			for i = 1, #kfs - 1 do
				if aan ~= aN then break end
				local k, nk = kfs[i], kfs[i + 1]
				
				-- Calcula o intervalo de tempo (Duration) escalonado com base no Class.Speed
				local fd = (nk.Time - k.Time) / speed
				
				if iF then
					iF = false
					if pA ~= "" then 
						local transTime = 0.25 / speed
						akt(k, transTime, Enum.EasingStyle.Cubic); task.wait(transTime)
					else 
						akt(k, fd, Enum.EasingStyle.Linear); task.wait(fd) 
					end
				else 
					akt(k, fd, Enum.EasingStyle.Linear); task.wait(fd) 
				end
				pke(k.Name)
			end
			
			-- Se a animação não for em loop (Class.Looped = false), finaliza no último frame
			if not lp and aan == aN then 
				local endTime = 0.15 / speed
				akt(kfs[#kfs], endTime, Enum.EasingStyle.Quad)
				task.wait(endTime)
				if aan == aN then aan = "" end -- Reseta o estado para livre após acabar
				break 
			end
		until not lp or aan ~= aN
	end)
end

local function ST()
	aan = ""
	for n, t in pairs(aTh) do task.cancel(t) end; aTh = {}
	local ti = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	for _, b in pairs(bns) do
		if abt[b.Name] then abt[b.Name]:Cancel() end
		TS:Create(b, ti, {Transform = CFrame.new()}):Play()
	end
end

local function asnd(snd, p)
	if not snd then return end
	local s = snd:Clone(); s.Parent = p; s:Play()
	task.spawn(function() s.Ended:Wait(); s:Destroy() end)
	return s
end

local function rsnd(f)
	if not f then return end; local c = f:GetChildren()
	if #c > 0 then return c[mR(1, #c)] end
end

local function avfx(f, t, p, ec)
	if not p then return end
	local cf = CFrame.new(t.Position, f.Position)
	local inst = p:Clone(); inst.CFrame = cf; inst.Parent = ws
	for _, pt in pairs(inst:GetDescendants()) do
		if pt:IsA("ParticleEmitter") then pt:Emit(pt:GetAttribute("EmitCount") or ec or 15) end
	end
	DB:AddItem(inst, 10)
end

local function trnq(p, e)
	local hm = p:FindFirstChildWhichIsA("Humanoid")
	local t = p:FindFirstChild("Torso") or p:FindFirstChild("UpperTorso")
	local hr = p:FindFirstChild("HumanoidRootPart")
	if e == "on" then
		if hm then hm.PlatformStand = true end; task.wait(0.1)
		if t then t.CanCollide = false end; if hr then hr.CanCollide = false end
		for _, v in pairs(p:GetDescendants()) do
			if v:IsA("BasePart") and not v.Massless then v.Massless = true end
		end
	else
		if hm then hm.PlatformStand = false end; task.wait(0.1)
		if t then t.CanCollide = true end; if hr then hr.CanCollide = true end
		for _, v in pairs(p:GetDescendants()) do
			if v:IsA("BasePart") and v.Massless then v.Massless = false end
		end
	end
end

-- Função auxiliar para restaurar o Locust exatamente ao estado inicial original
local function resetToInitialState()
	Hum.PlatformStand = false
	Hum.HipHeight = INITIAL_HIPHEIGHT
	for part, state in pairs(INITIAL_PART_STATES) do
		if part and part.Parent then
			part.CanCollide = state.CanCollide
			part.Massless = state.Massless
		end
	end
	HRP.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
	HRP.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
end

-- ==================== CONTROLE DE ESTADOS E FLINCH ====================
local Mv, idl, Stn = true, false, false
local OS, Spd, RT, spr = 13, 13, 1, false
local cdl = {}
local function gc(n) return table.find(cdl, n) ~= nil end
local function acd(n) if not gc(n) then table.insert(cdl, n) end end
local function rcd(n) local i = table.find(cdl, n); if i then table.remove(cdl, i) end end

local HD, CD, lh = 70, 0, Hum.Health
Hum.HealthChanged:Connect(function(nh)
	if nh < lh then
		local d = lh - nh; CD = CD + d
		task.delay(0.05, function() CD = 0 end)
		if CD >= HD and not Stn then
			Stn = true; Mv = false; Spd = 0; ST()
			local ps = SF and SF:FindFirstChild("painsounds")
			if ps then local s = asnd(ps:FindFirstChild("pain"), HRP); if s then s.PlaybackSpeed = Random.new():NextNumber(0.8, 1) end end
			PT("Flinch" .. mR(1, 3), false, 1)
			task.wait(1.5)
			Stn = false; Spd = OS; Mv = true; idl = false
		end
	end
	lh = nh
end)

-- ==================== AÇÕES REFORMULADAS ====================
local function eA(g, a)
	if g == "attack" and not gc("A") and RT ~= 3 and RT ~= 4 then
		acd("A")
		local hb = Instance.new("Part", ws); hb.Transparency = 1; hb.CanCollide = false; hb.Size = Vector3.new(10, 12, 10)
		hb.CFrame = HRP.CFrame * CFrame.new(0, 0, -4)
		local w = Instance.new("WeldConstraint", hb); w.Part0 = hb; w.Part1 = HRP
		for _, p in pairs(ws:GetPartsInPart(hb)) do
			if p and p.Parent and p.Parent:FindFirstChildWhichIsA("Humanoid") and p.Parent ~= C then
				local th = p.Parent:FindFirstChild("HumanoidRootPart")
				if SF and th then asnd(SF:FindFirstChild("hit" .. mR(1, 7)), th) end
				break
			end
		end
		task.wait(0.15); hb:Destroy(); rcd("A")
		
	elseif g=="attack2" and not gc("A") and RT~=3 and RT~=4 then
		Mv = false; Spd = 0; ST(); acd("A")
		local hb = Instance.new("Part", ws); hb.Transparency = 1; hb.CanCollide = false; hb.Size = Vector3.new(15, 20, 15)
		hb.CFrame = HRP.CFrame * CFrame.new(0, -3, -8); local w = Instance.new("WeldConstraint", hb); w.Part0 = hb; w.Part1 = HRP
		local tgt = nil
		for _, v in pairs(ws:GetPartsInPart(hb)) do
			if v and v.Parent and v.Parent:FindFirstChildWhichIsA("Humanoid") and v.Parent ~= C then tgt = v.Parent; break end
		end
		if tgt then
			local tHrp = tgt:FindFirstChild("HumanoidRootPart"); local tHum = tgt:FindFirstChildWhichIsA("Humanoid")
			if SF and tHrp then
				asnd(SF:FindFirstChild("hit" .. mR(1, 7)), tHrp)
				local snd2 = SF:FindFirstChild("pick") or SF:FindFirstChild("stab")
				if snd2 then asnd(snd2, tHrp) end
			end
			trnq(tgt, "on")
			local bv = Instance.new("BodyPosition", tHrp); bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge); bv.D = 900; bv.P = 20000
			local av = Instance.new("BodyGyro", tHrp); av.MaxTorque = Vector3.new(math.huge, math.huge, math.huge); av.P = 15000; av.D = 250
			local hd2 = C:FindFirstChild("head2")
			
			local pl = true
			task.spawn(function()
				while pl do
					if hd2 then av.CFrame = hd2.CFrame; bv.Position = hd2.Position end
					task.wait()
				end
			end)
			
			-- Eat2 / Jumpscare roda com velocidade aumentada 2.5 como no DogServer
			PT("jumpscare", false, 2.5)
			local cn; cn = kfEvt.Event:Connect(function(kf)
				if kf == "hitreg" then
					if SF and SF:FindFirstChild("Hitsounds") then asnd(rsnd(SF.Hitsounds), tHrp) end
					for c = 1, mR(25, 35) do
						task.spawn(function()
							local p = Instance.new("Part", ws); p.Size = Vector3.new(Random.new():NextNumber(0.5, 0.9), Random.new():NextNumber(0.5, 0.9), Random.new():NextNumber(0.5, 0.9))
							p.Position = tHrp.Position; p.Color = Color3.fromRGB(66, 0, 1); p.Material = Enum.Material.Mud
							local a1 = Instance.new("Attachment", p); a1.CFrame = CFrame.new(0, p.Size.Y / 2, 0)
							local a2 = Instance.new("Attachment", p); a2.CFrame = CFrame.new(0, -p.Size.Y / 2, 0)
							local tr = DS and DS:FindFirstChild("Trail")
							if tr then local trl = tr:Clone(); trl.Parent = p; trl.Attachment0 = a2; trl.Attachment1 = a1 end
							local pbv = Instance.new("BodyVelocity", p); pbv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
							pbv.Velocity = Vector3.new(mR(-45, 45), mR(25, 70), mR(-45, 45))
							DB:AddItem(pbv, 0.05); DB:AddItem(p, mR(10, 12))
						end)
					end
					if DS and DS:FindFirstChild("hit") then avfx(HRP, tHrp, DS.hit, 20) end
					
					-- Executa o dano letal e arremesso de partes corporais
					tHum:TakeDamage(3887)
					if tHum.Health <= 0 then
						local fbv = Instance.new("BodyVelocity", tHrp); fbv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
						fbv.Velocity = HRP.CFrame.LookVector * 20 + Vector3.new(0, 60, 0); DB:AddItem(fbv, 0.2)
						local function lI(it)
							if not it then return end
							local ic = it:Clone(); ic.Parent = ws; ic:SetPrimaryPartCFrame(tHrp.CFrame)
							for _, v in pairs(ic:GetChildren()) do if v:IsA("Part") then v.Anchored = false end end
							local ibv = Instance.new("BodyVelocity", ic.PrimaryPart); ibv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
							ibv.Velocity = Vector3.new(mR(-15, 15), mR(45, 65), mR(-15, 15)); DB:AddItem(ibv, 0.2); DB:AddItem(ic, mR(7, 20))
						end
						lI(DS and DS:FindFirstChild("intestine1")); lI(DS and DS:FindFirstChild("intestine2"))
					end
					cn:Disconnect()
				end
			end)
			
			-- TRAVA DINÂMICA: Aguarda a animação manual rodar por completo a tabela de frames
			repeat task.wait() until aan ~= "jumpscare"
			
			pl = false; bv:Destroy(); av:Destroy(); if tHum.Health > 0 then trnq(tgt, "off") end
		else task.wait(1.1) end
		hb:Destroy(); Spd = OS; Mv = true; idl = false; rcd("A")
		
	elseif g == "attack3" and not gc("A") then
		Mv = false; Spd = 0; ST(); acd("A")
		if SpF then local r = asnd(rsnd(SpF), HRP); if r then r.Name = "roar" end end
		task.wait(1.5); Mv = true; Spd = OS; idl = false; rcd("A")

	elseif g == "sprint" and RT ~= 3 and RT ~= 4 then
		spr = a and a.on or false
		RT = spr and 2 or 1; OS = spr and 45 or 13; Spd = OS; idl = false
		
	elseif g == "crouch" and not gc("A") and RT ~= 4 then
		Mv = false; Spd = 0; ST()
		if gc("C") then
			acd("A"); rcd("C"); PT("idle", true, 1)
			TS:Create(Hum, TweenInfo.new(0.6, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {HipHeight = INITIAL_HIPHEIGHT}):Play()
			task.wait(0.5); Mv = true; RT = 1; Spd = 13; OS = Spd; spr = false; rcd("A")
		else
			acd("C"); acd("A"); PT("crouchidle", true, 2.5) -- CrouchIdle:AdjustSpeed(2.5)
			TS:Create(Hum, TweenInfo.new(0.6, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {HipHeight = 4.5}):Play()
			task.wait(0.5); Mv = true; Spd = 13; OS = Spd; RT = 3; rcd("A")
		end; idl = false
		
	elseif g == "sit" and not gc("A") then
		Mv = false; Spd = 0; ST(); rcd("C")
		if gc("S") then
			acd("A"); rcd("S")
			resetToInitialState()
			PT("idle", true, 1)
			task.wait(0.5)
			
			local camCFrame = ws.CurrentCamera.CFrame
			HRP.CFrame = CFrame.new(HRP.Position, HRP.Position + Vector3.new(camCFrame.LookVector.X, 0, camCFrame.LookVector.Z))
			
			Mv = true; RT = 1; Spd = 13; OS = Spd; spr = false; rcd("A")
		else
			acd("S"); acd("A")
			PT("sit", true, 1)
			task.wait(0.5); rcd("A"); RT = 4
		end; idl = false
	end
end

-- ==================== LOOP NATIVO MAIN (WALKSPEED + VELOCIDADES DOGSERVER) ====================
task.spawn(function()
	while true do
		task.wait(); Hum.WalkSpeed = Spd
		if Mv then
			if Hum.MoveDirection == Vector3.new(0, 0, 0) then
				if not idl then
					idl = true
					if RT == 3 then 
						PT("crouchidle", true, 2.5) -- CrouchIdle:AdjustSpeed(2.5)
					elseif RT == 4 then 
						PT("sit", true, 1) 
					else 
						PT("idle", true, 1) 
					end
				end
			else
				if idl then
					idl = false
					if RT == 1 then 
						PT("walk", true, 2.5)      -- Walk:AdjustSpeed(2.5)
					elseif RT == 2 then 
						PT("run", true, 4)         -- Run:AdjustSpeed(4)
					elseif RT == 3 then 
						PT("crouchwalk", true, 2.5) -- CrouchWalk:AdjustSpeed(2.5)
					end
				end
			end
		end
	end
end)

if VF then
	task.spawn(function()
		while true do
			task.wait(mR(6, 15)); local vcs = VF:GetChildren()
			if #vcs > 0 and aan ~= "jumpscare" then
				local vc = vcs[mR(1, #vcs)]:Clone(); vc.Parent = HRP; vc.PlaybackSpeed = vc.PlaybackSpeed + Random.new():NextNumber(-0.1, 0.2)
				vc:Play(); vc.Ended:Wait(); vc:Destroy()
			end
		end
	end)
end

