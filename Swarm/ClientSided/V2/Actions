-- MOTOR LOCUST - LOADSTRING 2: INTERPRETADOR DE AÇÕES (COMPACTO CLIENT-SIDE)
-- =============================================================================
local core = shared.LocustCore
if not core then error("Erro: O Loadstring 1 precisa ser executado primeiro.") end

local TS = game:GetService("TweenService")
local DB = game:GetService("Debris")
local ws = workspace

local C = core.Character
local Hum = core.Humanoid
local HRP = core.HRP
local DS = core.DogServer
local SF = core.Sounds
local VF = core.Vocals
local SpF = core.Speech
local state = core.State

-- Métodos Rápidos de Cooldown
local function getC(n) return table.find(state.CooldownList, n) ~= nil end
local function addC(n) if not getC(n) then table.insert(state.CooldownList, n) end end
local function remC(n) local i = table.find(state.CooldownList, n); if i then table.remove(state.CooldownList, i) end end

-- Sistema de Som Auxiliar
local function playS(snd, p, tp)
	if not snd then return end
	local s = snd:Clone(); s.Parent = p
	if tp then s.TimePosition = tp end
	s:Play(); task.spawn(function() s.Ended:Wait(); s:Destroy() end)
	return s
end

local function randS(f) if f then local c = f:GetChildren(); return #c > 0 and c[math.random(1, #c)] or nil end end

-- Emissor VFX Direto
local function vfx(var, ec, cf)
	if not var then return end
	local inst = var:Clone(); inst.CFrame = cf; inst.Parent = ws
	for _, p in pairs(inst:GetDescendants()) do
		if p:IsA("ParticleEmitter") then p:Emit(p:GetAttribute("EmitCount") or ec or 15) end
	end
	DB:AddItem(inst, 10)
	return inst
end

local function angVFX(from, to, var, ec)
	if not from or not to then return end
	vfx(var, ec, CFrame.new(to.Position, from.Position))
end

-- Controle de Ocultamento
local function setInvis(b)
	local parts = {"Body", "Body2", "Body3", "NursePath", "NursePath2", "face", "face2", "face3"}
	for _, name in ipairs(parts) do
		local p = C:FindFirstChild(name)
		if p and p:IsA("BasePart") then p.Transparency = b and 1 or 0 end
	end
	local invVal = C:FindFirstChild("invis") or Instance.new("BoolValue", C)
	invVal.Name = "invis"; invVal.Value = b
	local amb, cls = HRP:FindFirstChild("ambience"), HRP:FindFirstChild("close ambience")
	if b then if amb then amb:Stop() end; if cls then cls:Stop() end
	else if amb then amb:Play() end; if cls then cls:Play() end end
end

-- Desativação Física do Alvo
local function trnq(p, mode)
	local hm = p:FindFirstChildWhichIsA("Humanoid")
	local t = p:FindFirstChild("Torso") or p:FindFirstChild("UpperTorso")
	local hr = p:FindFirstChild("HumanoidRootPart")
	local st = (mode == "on")
	if hm then hm.PlatformStand = st end; task.wait(0.1)
	if t then t.CanCollide = not st end; if hr then hr.CanCollide = not st end
	for _, v in pairs(p:GetDescendants()) do if v:IsA("BasePart") then v.Massless = st end end
end

-- EXPOSIÇÃO DA FUNÇÃO CENTRAL (Processa os comandos que vinham do RemoteEvent)
core.ProcessAction = function(goal, args)
	if state.Stunned or getC("Attacking") then return end
	local inv = C:FindFirstChild("invis")
	local isInvis = inv and inv.Value or false

	if goal == "attack2" and not getC("crouching") and not getC("sit") and not isInvis then
		state.Mover = false; core.StopAnimation(); state.Speed = 2; addC("Attacking")
		
		-- Hitbox local instantânea por intersecção geométrica
		local hb = Instance.new("Part", ws); hb.Transparency = 1; hb.CanCollide = false; hb.Size = Vector3.new(15, 20, 15); hb.Massless = true
		hb.CFrame = HRP.CFrame * CFrame.new(0, -3, -8)
		local w = Instance.new("WeldConstraint", hb); w.Part0 = hb; w.Part1 = HRP
		task.wait(0.05)
		
		local tgt = nil
		for _, v in pairs(ws:GetPartsInPart(hb)) do
			if v and v.Parent and v.Parent:FindFirstChildWhichIsA("Humanoid") and v.Parent ~= C then
				tgt = v.Parent; break
			end
		end; hb:Destroy()

		if tgt then
			HRP.Anchored = true; Hum.AutoRotate = false
			local tHrp, tHum = tgt:FindFirstChild("HumanoidRootPart"), tgt:FindFirstChildWhichIsA("Humanoid")
			if tHrp and SF then
				playS(SF:FindFirstChild("hit" .. math.random(1, 7)), tHrp)
				playS(DS:FindFirstChild("pick"), tHrp)
				local sfSnd = SF:FindFirstChild("sounds")
				playS(randS(sfSnd and sfSnd:FindFirstChild("stab") or SF), tHrp)
			end
			
			trnq(tgt, "on")
			local bv = Instance.new("BodyPosition", tHrp); bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge); bv.D = 900; bv.P = 20000
			local av = Instance.new("BodyGyro", tHrp); av.MaxTorque = Vector3.new(math.huge, math.huge, math.huge); av.P = 15000; av.D = 250
			
			local pl = true
			task.spawn(function()
				local h2 = C:FindFirstChild("head2")
				while pl and h2 do av.CFrame = h2.CFrame; bv.Position = h2.Position; task.wait() end
			end)
			
			local cn; cn = core.KeyframeEvent:Connect(function(kf)
				if kf == "hitreg" and tHrp then
					for i = 1, math.random(25, 35) do
						task.spawn(function()
							local p = Instance.new("Part", ws); p.Size = Vector3.new(Random.new():NextNumber(0.5, 0.9), Random.new():NextNumber(0.5, 0.9), Random.new():NextNumber(0.5, 0.9))
							p.Position = tHrp.Position; p.Color = Color3.fromRGB(66, 0, 1); p.Material = Enum.Material.Mud
							local a1 = Instance.new("Attachment", p); a1.CFrame = CFrame.new(0, p.Size.Y/2, 0)
							local a2 = Instance.new("Attachment", p); a2.CFrame = CFrame.new(0, -p.Size.Y/2, 0)
							local tr = DS:FindFirstChild("Trail"); if tr then local trl = tr:Clone(); trl.Parent = p; trl.Attachment0 = a2; trl.Attachment1 = a1 end
							local pbv = Instance.new("BodyVelocity", p); pbv.MaxForce = Vector3.new(math.huge, math.huge, math.huge); pbv.Velocity = Vector3.new(math.random(-45, 45), math.random(25, 70), math.random(-45, 45))
							DB:AddItem(pbv, 0.05); DB:AddItem(p, math.random(10, 12))
						end)
					end
					if DS:FindFirstChild("hit") then angVFX(HRP, tHrp, DS.hit, 20) end
					
					if tHum.Health <= 3887 then
						local fbv = Instance.new("BodyVelocity", tHrp); fbv.MaxForce = Vector3.new(math.huge, math.huge, math.huge); fbv.Velocity = HRP.CFrame.LookVector * 20 + Vector3.new(0, 60, 0); DB:AddItem(fbv, 0.2)
						tHum.Health = 0
						local function launchI(it)
							if not it then return end
							local ic = it:Clone(); ic.Parent = ws; ic:SetPrimaryPartCFrame(tHrp.CFrame)
							for _, v in pairs(ic:GetChildren()) do if v:IsA("Part") then v.Anchored = false end end
							local ibv = Instance.new("BodyVelocity", ic.PrimaryPart); ibv.MaxForce = Vector3.new(math.huge, math.huge, math.huge); ibv.Velocity = Vector3.new(math.random(-15, 15), math.random(45, 65), math.random(-15, 15)); DB:AddItem(ibv, 0.2); DB:AddItem(ic, math.random(7, 20))
						end
						launchI(DS:FindFirstChild("intestine1")); launchI(DS:FindFirstChild("intestine2"))
					else
						local fbv = Instance.new("BodyVelocity", tHrp); fbv.MaxForce = Vector3.new(math.huge, math.huge, math.huge); fbv.Velocity = HRP.CFrame.LookVector * 10 + Vector3.new(0, 55, 0); DB:AddItem(fbv, 0.2)
					end
					if SF then
						playS(randS(SF:FindFirstChild("Hitsounds")), tHrp)
						playS(randS(SF:FindFirstChild("break")), tHrp)
						playS(randS(SF:FindFirstChild("tear")), tHrp)
					end
					tHum:TakeDamage(3887); cn:Disconnect()
				end
			end)
			
			core.PlayAnimation("jumpscare", false)
			if DS:FindFirstChild("attack2") then playS(DS.attack2, HRP) end
			task.wait(2.2)
			pl = false; bv:Destroy(); av:Destroy(); HRP.Anchored = false; Hum.AutoRotate = true
			if tHum.Health > 0 then trnq(tgt, "off") end
		end
		state.Speed = state.OriginalSpeed; state.Mover = true; remC("Attacking")

	elseif goal == "sprint" and not getC("crouching") and not getC("sit") then
		state.SprintActive = not state.SprintActive
		state.RunType = state.SprintActive and 2 or 1
		state.OriginalSpeed = state.SprintActive and 45 or 13
		state.Speed = state.OriginalSpeed

	elseif goal == "placetv" then
		addC("Attacking"); state.Mover = false; state.Speed = 0; core.StopAnimation(); setInvis(true)
		local tv = DS:FindFirstChild("tv") and DS.tv:Clone()
		if tv then
			tv.Parent = C:FindFirstChild("TV") or C; HRP.Anchored = true; Hum.AutoRotate = false
			tv:SetPrimaryPartCFrame(CFrame.new(HRP.Position + Vector3.new(0, 0, -5)))
			task.wait(1)
			setInvis(false)
			if DS:FindFirstChild("tv1") then playS(DS.tv1, HRP) end
			core.PlayAnimation("spawn", false)
			task.wait(1.5)
			TS:Create(HRP, TweenInfo.new(0.2, Enum.EasingStyle.Linear), {CFrame = HRP.CFrame * CFrame.new(0, 0, -7)}):Play()
			Hum.AutoRotate = true; state.Mover = true; HRP.Anchored = false
		end
		state.Speed = state.OriginalSpeed; remC("Attacking")

	elseif goal == "crouch" and not getC("sit") then
		state.Mover = false; state.Speed = 0; core.StopAnimation()
		if getC("crouching") then
			addC("Attacking"); remC("crouching")
			TS:Create(Hum, TweenInfo.new(0.5, Enum.EasingStyle.Linear), {HipHeight = core.INITIAL_HIPHEIGHT}):Play()
			task.wait(0.5)
			state.Mover = true; state.RunType = 1; state.OriginalSpeed = 13; state.Speed = 13; state.SprintActive = false; remC("Attacking")
		else
			addC("crouching"); addC("Attacking")
			TS:Create(Hum, TweenInfo.new(0.5, Enum.EasingStyle.Linear), {HipHeight = 4.5}):Play()
			task.wait(0.5)
			state.Mover = true; state.RunType = 3; state.OriginalSpeed = 13; state.Speed = 13; state.SprintActive = false; remC("Attacking")
		end

	elseif goal == "sit" then
		state.Mover = false; state.Speed = 0; core.StopAnimation(); remC("crouching")
		if getC("sit") then
			addC("Attacking"); remC("sit")
			TS:Create(Hum, TweenInfo.new(0.5, Enum.EasingStyle.Linear), {HipHeight = core.INITIAL_HIPHEIGHT}):Play()
			task.wait(0.5)
			state.Mover = true; state.RunType = 1; state.OriginalSpeed = 13; state.Speed = 13; state.SprintActive = false; remC("Attacking")
		else
			addC("sit"); addC("Attacking")
			TS:Create(Hum, TweenInfo.new(0.5, Enum.EasingStyle.Linear), {HipHeight = 0.07}):Play()
			task.wait(0.5); remC("Attacking"); state.RunType = 4
		end
		
	elseif goal == "manual" then
		if not HRP:FindFirstChild("roar") and SpF then local r = playS(randS(SpF), HRP); if r then r.Name = "roar" end end
	elseif goal == "manual2" then
		if not HRP:FindFirstChild("theme") and DS:FindFirstChild("theme") then playS(DS.theme, HRP) end
	end
end

-- Loop de Áudio Vocal Aleatório Autônomo
task.spawn(function()
	while true do
		task.wait(math.random(6, 15))
		local inv = C:FindFirstChild("invis")
		if VF and #VF:GetChildren() > 0 and (not inv or not inv.Value) and state.CurrentAnimation ~= "jumpscare" then
			local v = randS(VF):Clone(); v.Parent = HRP
			v.PlaybackSpeed = v.PlaybackSpeed + Random.new():NextNumber(-0.1, 0.2)
			v:Play(); v.Ended:Wait(); v:Destroy()
		end
	end
end)

