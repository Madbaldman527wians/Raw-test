shared.LocustCore = {}
local core = shared.LocustCore

local Character = script.Parent
local Humanoid = Character:FindFirstChildWhichIsA("Humanoid")
local Hrp = Character:FindFirstChild("HumanoidRootPart")
local Event = Character:WaitForChild("RemoteEvent")
local Reference = Character:FindFirstChild("RootPart")

-- Armazena os componentes no ambiente global compartilhado
core.Character = Character
core.Humanoid = Humanoid
core.HRP = Hrp
core.INITIAL_HIPHEIGHT = Humanoid and Humanoid.HipHeight or 12.1

local Animator = require(script.Animator)
local AnimationFolder = script.Animations
AnimationFolder.Parent = nil

task.spawn(function()
	local parent = Character.Parent
	repeat task.wait() until Character.Parent ~= parent
	AnimationFolder:Destroy()
end)

core.State = {
	CooldownList = {},
	Mover = true,
	Idling = false,
	Stunned = false,
	OriginalSpeed = 13,
	Speed = 13,
	RunType = 1,
	SprintActive = false
}
local state = core.State

local Animations = {
	CrouchIdle = Animator:LoadAnimation(Character, AnimationFolder.crouchidle),
	CrouchWalk = Animator:LoadAnimation(Character, AnimationFolder.crouchwalk),
	Sit = Animator:LoadAnimation(Character, AnimationFolder.sit),
	Eat2 = Animator:LoadAnimation(Character, AnimationFolder.jumpscare),
	Idle = Animator:LoadAnimation(Character, AnimationFolder.idle),
	Walk = Animator:LoadAnimation(Character, AnimationFolder.walk),
	Run = Animator:LoadAnimation(Character, AnimationFolder.run),
	TV = Animator:LoadAnimation(Character, AnimationFolder.spawn),
}

Animations.Run:AdjustSpeed(4)
Animations.Walk:AdjustSpeed(2.5)
Animations.CrouchWalk:AdjustSpeed(2.5)
Animations.CrouchIdle:AdjustSpeed(2.5)
Animations.TV:AdjustSpeed(2.5)
Animations.Eat2:AdjustSpeed(2.5)

core.StopAnimation = function()
	for _, v in pairs(Animations) do
		if v.IsPlaying then v:Stop() end
	end
end

-- Correção da Função VFX (Removido as tipagens que quebravam o loadstring)
local function checkPart(txt)
	local succ, result = pcall(function()
		if txt:IsA("Part") or txt:IsA("MeshPart") or txt:IsA("Model") or txt:IsA("UnionOperation") then 
			return true 
		end
		return false
	end)
	return succ and result
end

core.Vfx = function(parent, var, emitC, cframe)
	local instanc = checkPart(var) and var or parent:FindFirstChild(var) or var
	if not instanc then return end
	
	local instance = instanc:Clone()
	instance.CFrame = cframe
	instance.Parent = workspace
	
	for _, particle in pairs(instance:GetDescendants()) do
		if particle:IsA("ParticleEmitter") then
			particle:Emit(particle:GetAttribute("EmitCount") or emitC or 15)
		end
	end
	game.Debris:AddItem(instance, 10)
	return instance
end

-- Loop de Movimentação Corrigido com todos os 'end' alinhados
task.spawn(function()
	while true do
		task.wait()
		if Humanoid then
			Humanoid.WalkSpeed = state.Speed
			if state.Mover then
				if Humanoid.MoveDirection == Vector3.new(0, 0, 0) then
					if not state.Idling then
						state.Idling = true
						core.StopAnimation()
						if state.RunType == 3 then Animations.CrouchIdle:Play()
						elseif state.RunType == 4 then Animations.Sit:Play()
						else Animations.Idle:Play() end
					end
				else
					if state.Idling then
						state.Idling = false
						core.StopAnimation()
						if state.RunType == 1 then Animations.Walk:Play()
						elseif state.RunType == 2 then Animations.Run:Play()
						elseif state.RunType == 3 then Animations.CrouchWalk:Play() end
					end
					
					-- Garante que a animação correta continue tocando se parar do nada
					if state.RunType == 1 and not Animations.Walk.IsPlaying then
						core.StopAnimation(); Animations.Walk:Play()
					elseif state.RunType == 2 and not Animations.Run.IsPlaying then
						core.StopAnimation(); Animations.Run:Play()
					elseif state.RunType == 3 and not Animations.CrouchWalk.IsPlaying then
						core.StopAnimation(); Animations.CrouchWalk:Play()
					end
				end
			end
		end
	end
end)

